<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.practice.metaphor.v1.mapper.BalanceMapperV1">

    <!-- 
        【Positional Strictly 版 ResultMap】 
        適用於 Java Record: 透過「型別 (javaType)」與「位置 (index-order)」精確對比建構子參數。
        這是當編譯器參數名稱 (-parameters) 因環境因素無法讀取時，最穩定的映射方式。
    -->
    <resultMap id="BalanceMap" type="com.practice.metaphor.v1.model.entity.BalanceV1">
        <constructor>
            <idArg column="id" javaType="Long"/>
            <arg column="trader_id" javaType="Long"/>
            <arg column="asset_id" javaType="Long"/>
            <arg column="available_amount" javaType="java.math.BigDecimal"/>
            <arg column="frozen_amount" javaType="java.math.BigDecimal"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>


    <select id="findAll" resultMap="BalanceMap">
        SELECT
            id,
            trader_id,
            asset_id,
            available_amount,
            frozen_amount,
            updated_at
        FROM balances
    </select>
    
    <select id="findByTraderId" resultMap="BalanceMap">
        SELECT
            id,
            trader_id,
            asset_id,
            available_amount,
            frozen_amount,
            updated_at
        FROM balances
        WHERE trader_id = #{traderId}
    </select>

    <select id="findByTraderIdAndAssetIdForUpdate" resultMap="BalanceMap">
        SELECT
            id,
            trader_id,
            asset_id,
            available_amount,
            frozen_amount,
            updated_at
        FROM balances
        WHERE trader_id = #{traderId}
          AND asset_id = #{assetId}
        FOR UPDATE
    </select>

    <update id="updateBalance">
        UPDATE balances
        SET available_amount = #{availableAmount},
            frozen_amount = #{frozenAmount},
            updated_at = NOW()
        WHERE trader_id = #{traderId}
          AND asset_id = #{assetId}
    </update>

</mapper>
