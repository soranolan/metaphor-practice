<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.practice.metaphor.v2.mapper.BalanceMapperV2">

    <resultMap id="BalanceMap" type="com.practice.metaphor.v2.model.entity.BalanceV2">
        <constructor>
            <idArg column="id" javaType="Long"/>
            <arg column="trader_id" javaType="Long"/>
            <arg column="asset_id" javaType="Long"/>
            <arg column="available_amount" javaType="java.math.BigDecimal"/>
            <arg column="frozen_amount" javaType="java.math.BigDecimal"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <select id="findAll" resultMap="BalanceMap">
        SELECT
            id,
            trader_id,
            asset_id,
            available_amount,
            frozen_amount,
            updated_at
        FROM
            balances
    </select>

    <!-- DB Projection 更新：基於當前值增減（因為我們沒有維護絕對餘額版本號）-->
    <update id="addAvailableAndDeductFrozen">
        UPDATE
            balances
        SET
            available_amount = available_amount + #{addAvailable},
            frozen_amount = frozen_amount - #{deductFrozen},
            updated_at = NOW()
        WHERE
            trader_id = #{traderId}
            AND asset_id = #{assetId}
    </update>

</mapper>
