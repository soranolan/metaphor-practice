<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.practice.metaphor.v1.mapper.MarketMapperV1">

    <resultMap id="MarketMap" type="com.practice.metaphor.v1.model.entity.MarketV1">
        <constructor>
            <idArg column="id" javaType="Long"/>
            <arg column="base_asset_id" javaType="Long"/>
            <arg column="quote_asset_id" javaType="Long"/>
            <arg column="symbol" javaType="String"/>
            <arg column="status" javaType="Integer"/>
        </constructor>
    </resultMap>

    <select id="findById" resultMap="MarketMap">
        SELECT
            id,
            base_asset_id,
            quote_asset_id,
            symbol,
            status
        FROM
            markets
        WHERE
            id = #{id}
    </select>

</mapper>
